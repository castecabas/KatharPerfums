<%
  const precioFormateado = '$' + parseFloat(producto.precio).toLocaleString('es-CO') + ' COP';
  const nombreMarca = producto.marca ? producto.marca.nombre : '';
  const nombreCategoria = producto.categoria ? producto.categoria.nombre : '';
  const nombreFamilia = producto.familiaOlfativa ? producto.familiaOlfativa.nombre : '';
%>

<div class="product-card"
     data-brand="<%= nombreMarca %>"
     data-name="<%= producto.nombre %>"
     data-price="<%= producto.precio %>"
     onclick="window.location.href='/catalogo/<%= producto.slug %>'"
     style="cursor:pointer;<%= producto.stock === 0 ? 'opacity:0.6;' : '' %>">

  <!-- ─── Imagen con flip ─── -->
  <div class="card-image-wrap">
    <div class="card-shimmer"></div>
    <div class="card-image-inner">

      <!-- Frente -->
      <div class="card-face card-front">
        <% if (producto.imagen && producto.imagen !== 'default.jpg') { %>
          <img src="/uploads/<%= producto.imagen %>"
               class="card-product-img"
               alt="<%= producto.nombre %>">
        <% } else { %>
          <div class="bottle-display">🧴</div>
        <% } %>

        <% if (producto.destacado) { %>
          <div class="card-badge oferta">✦ Destacado</div>
        <% } %>
        <% if (producto.stock === 0) { %>
          <div class="card-badge agotado">Agotado</div>
        <% } %>
      </div>

      <!-- Reverso (hover) -->
      <div class="card-face card-back">
        <div class="back-title"><%= producto.nombre %></div>
        <div class="back-desc">
          <%= producto.descripcion
                ? producto.descripcion.substring(0, 80) + '...'
                : 'Fragancia exclusiva KatharPerfums' %>
        </div>
        <div class="back-notes">
          <% if (nombreMarca) { %>
            <span class="note-chip"><%= nombreMarca %></span>
          <% } %>
          <% if (nombreCategoria) { %>
            <span class="note-chip"><%= nombreCategoria %></span>
          <% } %>
          <% if (nombreFamilia) { %>
            <span class="note-chip">🌸 <%= nombreFamilia %></span>
          <% } %>
        </div>
        <% if (producto.stock === 0) { %>
          <button class="back-btn" style="opacity:0.5;cursor:not-allowed;">✕ Agotado</button>
        <% } else { %>
          <button class="back-btn"
            onclick="event.stopPropagation();window.location.href='/catalogo/<%= producto.slug %>'">
            ✦ Ver Detalle
          </button>
        <% } %>
      </div>

    </div>
  </div>

  <!-- ─── Info ─── -->
  <div class="card-info">
    <% if (nombreMarca) { %>
      <div class="card-brand"><%= nombreMarca %></div>
    <% } %>
    <div class="card-name"><%= producto.nombre %></div>
    <% if (nombreFamilia) { %>
      <div class="card-size">🌸 <%= nombreFamilia %></div>
    <% } else if (nombreCategoria) { %>
      <div class="card-size"><%= nombreCategoria %></div>
    <% } %>
  </div>

  <!-- ─── Footer — solo precio y WhatsApp ─── -->
  <div class="card-footer">
    <div class="card-price"><%= precioFormateado %></div>
    <a href="https://wa.me/573054291055?text=Hola!%20Me%20interesa%20el%20perfume%20*<%= encodeURIComponent(producto.nombre) %>*<%= nombreMarca ? '%20de%20' + encodeURIComponent(nombreMarca) : '' %>.%20%C2%BFEst%C3%A1%20disponible?"
       class="card-wa"
       target="_blank"
       rel="noopener"
       onclick="event.stopPropagation()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </div>

</div>