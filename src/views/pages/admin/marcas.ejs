<% layout = 'layouts/main' %>
<% seccionAdmin = 'marcas' %>

<style>
:root{--sidebar-w:260px;}
.admin-layout{display:flex;min-height:calc(100vh - 65px);}
.sidebar{width:var(--sidebar-w);background:linear-gradient(180deg,#0d0d0d,#0a0005);border-right:1px solid rgba(201,168,76,0.2);padding:24px 16px;flex-shrink:0;position:sticky;top:65px;height:calc(100vh - 65px);overflow-y:auto;scrollbar-width:thin;}
.sidebar::-webkit-scrollbar{width:4px;}.sidebar::-webkit-scrollbar-thumb{background:rgba(201,168,76,0.3);border-radius:2px;}
.nav-section-title{font-family:var(--font-titulo);font-size:9px;letter-spacing:3px;color:rgba(201,168,76,0.5);text-transform:uppercase;margin:24px 0 10px;padding-bottom:6px;border-bottom:1px solid rgba(201,168,76,0.1);}
.nav-section-title:first-child{margin-top:0;}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid transparent;transition:all 0.2s;margin-bottom:4px;font-family:var(--font-titulo);font-size:10px;letter-spacing:1.5px;color:rgba(245,237,214,0.6);text-transform:uppercase;text-decoration:none;}
.nav-item:hover,.nav-item.active{background:rgba(201,168,76,0.07);border-color:rgba(201,168,76,0.2);color:var(--gold);}
.nav-item.active{border-left:2px solid var(--gold);}
.nav-icon{font-size:14px;width:18px;text-align:center;}
.nav-count{margin-left:auto;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);color:var(--gold);font-size:9px;padding:2px 6px;}
.main{flex:1;padding:32px 36px;}
.page-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:16px;}
.page-header-left .eyebrow{font-family:var(--font-titulo);font-size:10px;letter-spacing:5px;color:var(--gold);opacity:0.7;margin-bottom:8px;}
.page-header-left h1{font-family:var(--font-elegante);font-size:32px;font-weight:300;color:var(--cream);letter-spacing:2px;}
.page-header-left h1 em{font-style:italic;color:var(--gold);}
.btn-add{background:linear-gradient(135deg,rgba(201,168,76,0.2),rgba(155,27,90,0.2));border:1px solid rgba(201,168,76,0.4);color:var(--gold-light);padding:10px 20px;font-family:var(--font-titulo);font-size:9px;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:all 0.25s;display:inline-flex;align-items:center;gap:8px;}
.btn-add:hover{border-color:var(--gold);}
.marcas-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;}
.marca-card{background:linear-gradient(135deg,rgba(201,168,76,0.05),rgba(155,27,90,0.03));border:1px solid rgba(201,168,76,0.15);padding:24px;position:relative;overflow:hidden;transition:border-color 0.3s;}
.marca-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--magenta);}
.marca-card:hover{border-color:rgba(201,168,76,0.35);}
.marca-nombre{font-family:var(--font-titulo);font-size:13px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:4px;}
.marca-slug{font-family:var(--font-cuerpo);font-size:10px;color:rgba(245,237,214,0.3);letter-spacing:1px;margin-bottom:16px;}
.card-actions{display:flex;gap:8px;}
.tbl-btn{background:transparent;border:1px solid rgba(201,168,76,0.2);color:rgba(245,237,214,0.5);padding:5px 12px;font-family:var(--font-titulo);font-size:9px;letter-spacing:1px;cursor:pointer;transition:all 0.2s;text-transform:uppercase;}
.tbl-btn:hover{border-color:var(--gold);color:var(--gold);}
.tbl-btn.del{border-color:rgba(231,76,60,0.2);color:rgba(231,76,60,0.5);}
.tbl-btn.del:hover{border-color:rgba(231,76,60,0.6);color:rgba(231,76,60,0.9);}
.empty-state{text-align:center;padding:80px 24px;}
.empty-icon{font-size:48px;opacity:0.2;margin-bottom:16px;}
.empty-text{font-family:var(--font-elegante);font-size:20px;color:rgba(245,237,214,0.35);font-style:italic;}
/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:500;display:none;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.open{display:flex;}
.modal{background:linear-gradient(160deg,#0f0f0f,#0a0005);border:1px solid rgba(201,168,76,0.25);width:100%;max-width:440px;position:relative;}
.modal::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),var(--magenta),transparent);}
.modal-header{padding:24px 28px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(201,168,76,0.1);}
.modal-title{font-family:var(--font-titulo);font-size:13px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;}
.modal-close{background:none;border:1px solid rgba(201,168,76,0.2);color:rgba(245,237,214,0.4);width:30px;height:30px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.modal-close:hover{border-color:rgba(231,76,60,0.4);color:rgba(231,76,60,0.7);}
.modal-body{padding:24px 28px;}
.form-group{margin-bottom:18px;}
.form-label{font-family:var(--font-titulo);font-size:9px;letter-spacing:2px;color:rgba(201,168,76,0.7);text-transform:uppercase;display:block;margin-bottom:6px;}
.form-input{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(201,168,76,0.2);color:var(--cream);padding:10px 14px;font-family:var(--font-cuerpo);font-size:13px;outline:none;transition:border-color 0.3s;}
.form-input::placeholder{color:rgba(245,237,214,0.25);}
.form-input:focus{border-color:rgba(201,168,76,0.5);}
.modal-footer{padding:16px 28px 24px;display:flex;gap:10px;justify-content:flex-end;border-top:1px solid rgba(201,168,76,0.1);}
.btn-cancel{background:transparent;border:1px solid rgba(245,237,214,0.15);color:rgba(245,237,214,0.4);padding:10px 20px;font-family:var(--font-titulo);font-size:9px;letter-spacing:2px;cursor:pointer;text-transform:uppercase;transition:all 0.2s;}
.btn-cancel:hover{border-color:rgba(245,237,214,0.3);color:rgba(245,237,214,0.7);}
.btn-save{background:linear-gradient(135deg,rgba(201,168,76,0.2),rgba(155,27,90,0.2));border:1px solid rgba(201,168,76,0.5);color:var(--gold-light);padding:10px 24px;font-family:var(--font-titulo);font-size:9px;letter-spacing:3px;cursor:pointer;text-transform:uppercase;transition:all 0.25s;}
.btn-save:hover{border-color:var(--gold);}
</style>

<div class="admin-layout">
  <%- include('../../components/admin-sidebar', {
    seccionAdmin,
    totalProductos:  0,
    totalCategorias: 0,
    totalMarcas:     marcas.length,
    totalFamilias:   0,
  }) %>

  <main class="main">
    <div class="page-header">
      <div class="page-header-left">
        <p class="eyebrow">✦ Administración</p>
        <h1>Gestión de <em>Marcas</em></h1>
      </div>
      <button class="btn-add" onclick="abrirModalCrear()">✦ Nueva Marca</button>
    </div>

    <% if (marcas && marcas.length > 0) { %>
      <div class="marcas-grid">
        <% marcas.forEach(m => { %>
        <div class="marca-card">
          <div class="marca-nombre"><%= m.nombre %></div>
          <div class="marca-slug">/<%= m.slug %></div>
          <div class="card-actions">
            <button class="tbl-btn"
              onclick="abrirModalEditar('<%= m.id %>','<%= m.nombre.replace(/'/g, "\\'") %>')">
              ✎ Editar
            </button>
            <form method="POST" action="/admin/marcas/eliminar/<%= m.id %>"
                  style="display:inline"
                  onsubmit="return confirm('¿Eliminar la marca <%= m.nombre %>?')">
              <button type="submit" class="tbl-btn del">✕ Eliminar</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">🏷</div>
        <div class="empty-text">No hay marcas — Crea la primera</div>
      </div>
    <% } %>
  </main>
</div>

<!-- Modal Crear -->
<div class="modal-overlay" id="modal-crear">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">✦ Nueva Marca</span>
      <button class="modal-close" onclick="cerrarModal('modal-crear')">✕</button>
    </div>
    <form method="POST" action="/admin/marcas/crear">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Nombre *</label>
          <input class="form-input" type="text" name="nombre"
                 placeholder="Ej: Dior, Chanel, Lattafa" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="cerrarModal('modal-crear')">Cancelar</button>
        <button type="submit" class="btn-save">✦ Guardar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Editar -->
<div class="modal-overlay" id="modal-editar">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">✎ Editar Marca</span>
      <button class="modal-close" onclick="cerrarModal('modal-editar')">✕</button>
    </div>
    <form id="form-editar" method="POST" action="">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Nombre *</label>
          <input class="form-input" type="text" name="nombre" id="edit-nombre" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="cerrarModal('modal-editar')">Cancelar</button>
        <button type="submit" class="btn-save">✦ Actualizar</button>
      </div>
    </form>
  </div>
</div>

<script>
function abrirModalCrear() { document.getElementById('modal-crear').classList.add('open'); }
function abrirModalEditar(id, nombre) {
  document.getElementById('edit-nombre').value = nombre;
  document.getElementById('form-editar').action = '/admin/marcas/editar/' + id;
  document.getElementById('modal-editar').classList.add('open');
}
function cerrarModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});
</script>
