<% layout = 'layouts/main' %>
<% seccionAdmin = 'dashboard' %>

<style>
:root{--sidebar-w:260px;}
.admin-layout{display:flex;min-height:calc(100vh - 65px);}
.sidebar{width:var(--sidebar-w);background:linear-gradient(180deg,#0d0d0d,#0a0005);border-right:1px solid rgba(201,168,76,0.2);padding:24px 16px;flex-shrink:0;position:sticky;top:65px;height:calc(100vh - 65px);overflow-y:auto;scrollbar-width:thin;}
.sidebar::-webkit-scrollbar{width:4px;}.sidebar::-webkit-scrollbar-thumb{background:rgba(201,168,76,0.3);border-radius:2px;}
.nav-section-title{font-family:'Cinzel',serif;font-size:9px;letter-spacing:3px;color:rgba(201,168,76,0.5);text-transform:uppercase;margin:24px 0 10px;padding-bottom:6px;border-bottom:1px solid rgba(201,168,76,0.1);}
.nav-section-title:first-child{margin-top:0;}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;cursor:pointer;border:1px solid transparent;transition:all 0.2s;margin-bottom:4px;font-family:'Cinzel',serif;font-size:10px;letter-spacing:1.5px;color:rgba(245,237,214,0.6);text-transform:uppercase;text-decoration:none;}
.nav-item:hover,.nav-item.active{background:rgba(201,168,76,0.07);border-color:rgba(201,168,76,0.2);color:var(--gold);}
.nav-item.active{border-left:2px solid var(--gold);}
.nav-icon{font-size:14px;width:18px;text-align:center;}
.nav-count{margin-left:auto;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);color:var(--gold);font-size:9px;padding:2px 6px;}
.main{flex:1;padding:32px 36px;}
.page-header{margin-bottom:32px;}
.page-header .eyebrow{font-family:'Cinzel',serif;font-size:10px;letter-spacing:5px;color:var(--gold);opacity:0.7;margin-bottom:8px;}
.page-header h1{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:300;color:var(--cream);letter-spacing:2px;}
.page-header h1 em{font-style:italic;color:var(--gold);}
/* Stats */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:36px;}
.stat-card{background:linear-gradient(135deg,rgba(201,168,76,0.06),rgba(155,27,90,0.04));border:1px solid rgba(201,168,76,0.2);padding:24px;position:relative;overflow:hidden;transition:border-color 0.3s;}
.stat-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--gold);}
.stat-card:nth-child(2)::before{background:var(--magenta);}
.stat-card:nth-child(3)::before{background:var(--rose);}
.stat-card:nth-child(4)::before{background:rgba(46,204,113,0.8);}
.stat-card:nth-child(5)::before{background:rgba(52,152,219,0.8);}
.stat-card:hover{border-color:rgba(201,168,76,0.4);}
.stat-icon{font-size:24px;margin-bottom:12px;opacity:0.7;}
.stat-label{font-family:'Cinzel',serif;font-size:9px;letter-spacing:3px;color:rgba(201,168,76,0.6);text-transform:uppercase;margin-bottom:8px;}
.stat-value{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:300;color:var(--cream);letter-spacing:2px;line-height:1;}
.stat-sub{font-family:'Montserrat',sans-serif;font-size:11px;color:rgba(245,237,214,0.35);margin-top:6px;}
/* Acciones */
.section-title-sm{font-family:'Cinzel',serif;font-size:10px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(201,168,76,0.15);}
.actions-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;}
.action-card{background:rgba(201,168,76,0.03);border:1px solid rgba(201,168,76,0.12);padding:20px;text-align:center;cursor:pointer;transition:all 0.25s;text-decoration:none;display:block;}
.action-card:hover{border-color:rgba(201,168,76,0.35);background:rgba(201,168,76,0.06);transform:translateY(-2px);}
.action-icon{font-size:28px;margin-bottom:10px;display:block;}
.action-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;}
.action-desc{font-size:11px;color:rgba(245,237,214,0.35);margin-top:4px;}
</style>

<div class="admin-layout">
  <%- include('../../components/admin-sidebar', {
    seccionAdmin,
    totalProductos,
    totalCategorias,
    totalMarcas,
    totalFamilias,
  }) %>

  <main class="main">
    <div class="page-header">
      <p class="eyebrow">✦ Panel Administrativo</p>
      <h1>Bienvenido al <em>Dashboard</em></h1>
    </div>

    <!-- Estadísticas -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">🧴</div>
        <div class="stat-label">Total Productos</div>
        <div class="stat-value"><%= totalProductos %></div>
        <div class="stat-sub">En catálogo</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🏷</div>
        <div class="stat-label">Categorías</div>
        <div class="stat-value"><%= totalCategorias %></div>
        <div class="stat-sub">Colecciones activas</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">✦</div>
        <div class="stat-label">Marcas</div>
        <div class="stat-value"><%= totalMarcas %></div>
        <div class="stat-sub">Registradas</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🌸</div>
        <div class="stat-label">Familias</div>
        <div class="stat-value"><%= totalFamilias %></div>
        <div class="stat-sub">Olfativas</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">✦</div>
        <div class="stat-label">Estado</div>
        <div class="stat-value" style="font-size:24px;color:var(--green);">Online</div>
        <div class="stat-sub">Tienda activa</div>
      </div>
    </div>

    <!-- Acciones rápidas -->
    <div class="quick-actions">
      <div class="section-title-sm">⚡ Acciones Rápidas</div>
      <div class="actions-grid">
        <a href="/admin/productos" class="action-card">
          <span class="action-icon">🧴</span>
          <div class="action-label">Productos</div>
          <div class="action-desc">Gestionar catálogo</div>
        </a>
        <a href="/admin/categorias" class="action-card">
          <span class="action-icon">🏷</span>
          <div class="action-label">Categorías</div>
          <div class="action-desc">Organizar colecciones</div>
        </a>
        <a href="/admin/marcas" class="action-card">
        <span class="action-icon">✦</span>
        <div class="action-label">Marcas</div>
        <div class="action-desc">Gestionar marcas</div>
      </a>
      <a href="/admin/familias" class="action-card">
        <span class="action-icon">🌸</span>
        <div class="action-label">Familias</div>
        <div class="action-desc">Familias olfativas</div>
      </a>
        <a href="/" target="_blank" class="action-card">
          <span class="action-icon">🌐</span>
          <div class="action-label">Ver Tienda</div>
          <div class="action-desc">Vista del cliente</div>
        </a>
      </div>
    </div>
  </main>
</div>
